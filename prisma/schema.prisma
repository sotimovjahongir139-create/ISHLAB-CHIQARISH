// Manufacturing Platform — Prisma Schema
// PostgreSQL | Enterprise-ready | Uzbek manufacturing context

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & RBAC
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  avatar       String?
  isActive     Boolean   @default(true)  @map("is_active")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id])

  departmentId String?    @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  factoryId    String?    @map("factory_id")
  factory      Factory?   @relation(fields: [factoryId], references: [id])

  employee          Employee?
  notifications     Notification[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@map("users")
  @@index([email])
  @@index([roleId])
  @@index([departmentId])
  @@index([factoryId])
  @@index([isActive])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId])
  @@index([token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String   @map("display_name")
  module      String
  action      String   // create | read | update | delete | export
  createdAt   DateTime @default(now()) @map("created_at")

  roles       RolePermission[]

  @@map("permissions")
  @@index([module])
  @@index([action])
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// ORGANIZATION
// ============================================================

model Factory {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  address   String?
  city      String?
  country   String?   @default("Uzbekistan")
  phone     String?
  isActive  Boolean   @default(true)  @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  users           User[]
  departments     Department[]
  warehouses      Warehouse[]
  productionLines ProductionLine[]
  equipment       Equipment[]

  @@map("factories")
  @@index([isActive])
}

model Warehouse {
  id        String        @id @default(cuid())
  name      String
  code      String        @unique
  type      WarehouseType @default(RAW_MATERIAL)
  capacity  Float?
  isActive  Boolean       @default(true)  @map("is_active")
  isDeleted Boolean       @default(false) @map("is_deleted")
  deletedAt DateTime?     @map("deleted_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt      @map("updated_at")

  factoryId String  @map("factory_id")
  factory   Factory @relation(fields: [factoryId], references: [id])

  materials Material[]

  @@map("warehouses")
  @@index([factoryId])
  @@index([type])
}

enum WarehouseType {
  RAW_MATERIAL
  FINISHED_GOODS
  SPARE_PARTS
  GENERAL
}

model Department {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  isActive    Boolean   @default(true)  @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  factoryId String  @map("factory_id")
  factory   Factory @relation(fields: [factoryId], references: [id])

  managerId String? @map("manager_id")

  users        User[]
  employees    Employee[]
  workHours    EmployeeWorkHour[]
  wasteRecords WasteRecord[]
  paintRecords PaintRecord[]

  @@map("departments")
  @@index([factoryId])
  @@index([isActive])
}

model Shift {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  startTime     String   @map("start_time")    // "08:00"
  endTime       String   @map("end_time")      // "16:00"
  durationHours Float    @map("duration_hours")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  productionPlans    ProductionPlan[]
  productionFacts    ProductionFact[]
  employeeAttendance EmployeeAttendance[]
  downtimes          Downtime[]
  workHours          EmployeeWorkHour[]

  @@map("shifts")
}

// ============================================================
// EMPLOYEES
// ============================================================

model Employee {
  id              String         @id @default(cuid())
  employeeNumber  String         @unique @map("employee_number")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  middleName      String?        @map("middle_name")
  birthDate       DateTime?      @db.Date @map("birth_date")
  gender          Gender?
  phone           String?
  address         String?
  position        String
  hireDate        DateTime       @db.Date @map("hire_date")
  terminationDate DateTime?      @db.Date @map("termination_date")
  salary          Decimal?       @db.Decimal(14, 2)
  status          EmployeeStatus @default(ACTIVE)
  photoUrl        String?        @map("photo_url")
  isDeleted       Boolean        @default(false) @map("is_deleted")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt      @map("updated_at")

  userId String?   @unique @map("user_id")
  user   User?     @relation(fields: [userId], references: [id])

  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  attendance   EmployeeAttendance[]
  performance  EmployeePerformance[]
  workHours    EmployeeWorkHour[]
  paintRecords PaintRecord[]

  @@map("employees")
  @@index([departmentId])
  @@index([status])
  @@index([employeeNumber])
}

enum Gender {
  MALE
  FEMALE
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  SUSPENDED
}

model EmployeeAttendance {
  id            String           @id @default(cuid())
  date          DateTime         @db.Date
  checkIn       DateTime?        @map("check_in")
  checkOut      DateTime?        @map("check_out")
  status        AttendanceStatus @default(PRESENT)
  workHours     Float?           @map("work_hours")
  overtimeHours Float?           @default(0) @map("overtime_hours")
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")

  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  shiftId String? @map("shift_id")
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  @@map("employee_attendance")
  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@index([status])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

model EmployeePerformance {
  id             String   @id @default(cuid())
  period         String   // "2024-01" YYYY-MM
  unitsProduced  Int?     @map("units_produced")
  defectsCount   Int?     @default(0) @map("defects_count")
  attendanceRate Float?   @map("attendance_rate")
  efficiencyRate Float?   @map("efficiency_rate")
  score          Float?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_performance")
  @@unique([employeeId, period])
  @@index([employeeId])
  @@index([period])
}

// ============================================================
// PRODUCTION
// ============================================================

model ProductionLine {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  capacity    Int?      // units per hour
  isActive    Boolean   @default(true)  @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  factoryId String  @map("factory_id")
  factory   Factory @relation(fields: [factoryId], references: [id])

  productionPlans ProductionPlan[]
  productionFacts ProductionFact[]
  equipment       Equipment[]
  downtimes       Downtime[]

  @@map("production_lines")
  @@index([factoryId])
  @@index([isActive])
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  models ProductModel[]

  @@map("product_categories")
}

model ProductModel {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  unit         String   @default("dona")
  standardTime Float?   @map("standard_time") // minutes per unit
  targetRate   Int?     @map("target_rate")   // units per shift
  isActive     Boolean  @default(true)  @map("is_active")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  categoryId String          @map("category_id")
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  productionPlans    ProductionPlan[]
  productionFacts    ProductionFact[]
  defects            Defect[]
  qualityInspections QualityInspection[]

  @@map("product_models")
  @@index([categoryId])
  @@index([isActive])
}

model ProductionPlan {
  id         String     @id @default(cuid())
  planDate   DateTime   @db.Date @map("plan_date")
  plannedQty Int        @map("planned_qty")
  status     PlanStatus @default(DRAFT)
  notes      String?
  isDeleted  Boolean    @default(false) @map("is_deleted")
  deletedAt  DateTime?  @map("deleted_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt      @map("updated_at")

  productionLineId String         @map("production_line_id")
  productionLine   ProductionLine @relation(fields: [productionLineId], references: [id])

  productModelId String?       @map("product_model_id")
  productModel   ProductModel? @relation(fields: [productModelId], references: [id])

  shiftId String? @map("shift_id")
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  productionFacts ProductionFact[]

  @@map("production_plan")
  @@index([planDate])
  @@index([productionLineId])
  @@index([productModelId])
  @@index([shiftId])
  @@index([status])
}

enum PlanStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionFact {
  id              String   @id @default(cuid())
  factDate        DateTime @db.Date  @map("fact_date")
  producedQty     Int      @map("produced_qty")
  defectQty       Int      @default(0) @map("defect_qty")
  goodQty         Int      @map("good_qty")
  startTime       DateTime? @map("start_time")
  endTime         DateTime? @map("end_time")
  actualMinutes   Float?    @map("actual_minutes")
  efficiency      Float?    // (producedQty / plannedQty) * 100
  oee             Float?    // Overall Equipment Effectiveness
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  productionLineId String         @map("production_line_id")
  productionLine   ProductionLine @relation(fields: [productionLineId], references: [id])

  productModelId String?       @map("product_model_id")
  productModel   ProductModel? @relation(fields: [productModelId], references: [id])

  shiftId String? @map("shift_id")
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  planId String?         @map("plan_id")
  plan   ProductionPlan? @relation(fields: [planId], references: [id])

  defects Defect[]

  @@map("production_fact")
  @@index([factDate])
  @@index([productionLineId])
  @@index([productModelId])
  @@index([shiftId])
  @@index([planId])
}

// ============================================================
// QUALITY CONTROL
// ============================================================

model DefectType {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  description String?
  severity    DefectSeverity @default(MINOR)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt      @map("updated_at")

  defects Defect[]

  @@map("defect_types")
  @@index([severity])
}

enum DefectSeverity {
  MINOR
  MAJOR
  CRITICAL
}

model QualityInspection {
  id             String           @id @default(cuid())
  inspectionDate DateTime         @db.Date @map("inspection_date")
  inspectedQty   Int              @map("inspected_qty")
  passedQty      Int              @map("passed_qty")
  failedQty      Int              @map("failed_qty")
  passRate       Float?           @map("pass_rate")
  status         InspectionStatus @default(PENDING)
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt      @map("updated_at")

  productModelId String       @map("product_model_id")
  productModel   ProductModel @relation(fields: [productModelId], references: [id])

  inspectorId String? @map("inspector_id")

  defects Defect[]

  @@map("quality_inspections")
  @@index([inspectionDate])
  @@index([productModelId])
  @@index([status])
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Defect {
  id          String       @id @default(cuid())
  quantity    Int          @default(1)
  description String?
  actionTaken String?      @map("action_taken")
  status      DefectStatus @default(OPEN)
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt      @map("updated_at")

  defectTypeId String     @map("defect_type_id")
  defectType   DefectType @relation(fields: [defectTypeId], references: [id])

  productionFactId String?         @map("production_fact_id")
  productionFact   ProductionFact? @relation(fields: [productionFactId], references: [id])

  productModelId String?       @map("product_model_id")
  productModel   ProductModel? @relation(fields: [productModelId], references: [id])

  inspectionId String?            @map("inspection_id")
  inspection   QualityInspection? @relation(fields: [inspectionId], references: [id])

  @@map("defects")
  @@index([defectTypeId])
  @@index([productionFactId])
  @@index([status])
  @@index([createdAt])
}

enum DefectStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

// ============================================================
// DOWNTIME
// ============================================================

model DowntimeReason {
  id          String            @id @default(cuid())
  name        String
  code        String            @unique
  category    DowntimeCategory
  description String?
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt      @map("updated_at")

  downtimes Downtime[]

  @@map("downtime_reasons")
  @@index([category])
}

enum DowntimeCategory {
  PLANNED
  UNPLANNED
  BREAKDOWN
  MAINTENANCE
  CHANGEOVER
  WAITING_MATERIAL
  OPERATOR
  OTHER
}

model Downtime {
  id              String         @id @default(cuid())
  startTime       DateTime       @map("start_time")
  endTime         DateTime?      @map("end_time")
  durationMinutes Float?         @map("duration_minutes")
  description     String?
  impact          String?
  status          DowntimeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt      @map("updated_at")

  productionLineId String         @map("production_line_id")
  productionLine   ProductionLine @relation(fields: [productionLineId], references: [id])

  reasonId String         @map("reason_id")
  reason   DowntimeReason @relation(fields: [reasonId], references: [id])

  equipmentId String?    @map("equipment_id")
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])

  shiftId String? @map("shift_id")
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  @@map("downtime")
  @@index([startTime])
  @@index([productionLineId])
  @@index([status])
  @@index([reasonId])
  @@index([equipmentId])
}

enum DowntimeStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

// ============================================================
// MATERIALS
// ============================================================

model Material {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  description  String?
  unit         String    @default("kg")
  category     String?
  minStock     Float?    @map("min_stock")
  maxStock     Float?    @map("max_stock")
  currentStock Float     @default(0) @map("current_stock")
  unitCost     Decimal?  @db.Decimal(14, 2) @map("unit_cost")
  isActive     Boolean   @default(true)  @map("is_active")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  transactions MaterialTransaction[]

  @@map("materials")
  @@index([warehouseId])
  @@index([code])
  @@index([category])
  @@index([currentStock])
}

model MaterialTransaction {
  id              String          @id @default(cuid())
  transactionDate DateTime        @db.Date @map("transaction_date")
  type            TransactionType
  quantity        Float
  unitCost        Decimal?        @db.Decimal(14, 2) @map("unit_cost")
  totalCost       Decimal?        @db.Decimal(14, 2) @map("total_cost")
  stockBefore     Float           @map("stock_before")
  stockAfter      Float           @map("stock_after")
  reference       String?         // invoice / order number
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")

  materialId  String   @map("material_id")
  material    Material @relation(fields: [materialId], references: [id])

  createdById String? @map("created_by_id")

  @@map("material_transactions")
  @@index([materialId])
  @@index([transactionDate])
  @@index([type])
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  TRANSFER
}

// ============================================================
// EQUIPMENT
// ============================================================

model Equipment {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  type           String
  brand          String?
  model          String?
  serialNumber   String?         @unique @map("serial_number")
  purchaseDate   DateTime?       @db.Date @map("purchase_date")
  warrantyExpiry DateTime?       @db.Date @map("warranty_expiry")
  status         EquipmentStatus @default(OPERATIONAL)
  location       String?
  description    String?
  isDeleted      Boolean         @default(false) @map("is_deleted")
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt      @map("updated_at")

  factoryId String  @map("factory_id")
  factory   Factory @relation(fields: [factoryId], references: [id])

  productionLineId String?         @map("production_line_id")
  productionLine   ProductionLine? @relation(fields: [productionLineId], references: [id])

  maintenances Maintenance[]
  downtimes    Downtime[]

  @@map("equipment")
  @@index([factoryId])
  @@index([status])
  @@index([productionLineId])
}

enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  BREAKDOWN
  RETIRED
  STANDBY
}

model Maintenance {
  id            String            @id @default(cuid())
  type          MaintenanceType
  scheduledDate DateTime          @db.Date @map("scheduled_date")
  completedDate DateTime?         @db.Date @map("completed_date")
  durationHours Float?            @map("duration_hours")
  cost          Decimal?          @db.Decimal(14, 2)
  description   String?
  workDone      String?           @map("work_done")
  partsReplaced String?           @map("parts_replaced")
  status        MaintenanceStatus @default(SCHEDULED)
  nextScheduled DateTime?         @db.Date @map("next_scheduled")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  equipmentId  String    @map("equipment_id")
  equipment    Equipment @relation(fields: [equipmentId], references: [id])

  technicianId String? @map("technician_id")

  @@map("maintenance")
  @@index([equipmentId])
  @@index([scheduledDate])
  @@index([status])
  @@index([type])
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  PREDICTIVE
  EMERGENCY
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique @map("order_number")
  customer     String?
  description  String?
  quantity     Int
  unit         String      @default("dona")
  dueDate      DateTime?   @db.Date @map("due_date")
  status       OrderStatus @default(PENDING)
  priority     Int         @default(1) // 1=low 5=critical
  notes        String?
  isDeleted    Boolean     @default(false) @map("is_deleted")
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt      @map("updated_at")

  @@map("orders")
  @@index([status])
  @@index([dueDate])
  @@index([orderNumber])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  COMPLETED
  CANCELLED
  ON_HOLD
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ALERT
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id         String       @id @default(cuid())
  name       String
  type       ReportType
  period     String       // "2024-01" | "2024-W03" | "2024-01-15"
  status     ReportStatus @default(GENERATING)
  fileUrl    String?      @map("file_url")
  format     String       @default("pdf") // pdf | excel | csv
  parameters Json?
  generatedAt DateTime?   @map("generated_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  generatedById String? @map("generated_by_id")

  @@map("reports")
  @@index([type])
  @@index([status])
  @@index([period])
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  SHIFT
  PRODUCTION
  QUALITY
  DOWNTIME
  MATERIAL
  EMPLOYEE
  EQUIPMENT
  DEPARTMENT
  CUSTOM
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
  EXPIRED
}

// ============================================================
// AUDIT & SETTINGS
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE | UPDATE | DELETE | LOGIN | EXPORT
  entity    String
  entityId  String?  @map("entity_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@index([action])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string") // string | number | boolean | json
  description String?
  group       String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
  @@index([group])
}

// ============================================================
// EMPLOYEE WORK HOURS
// ============================================================

model EmployeeWorkHour {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  hoursWorked Float    @map("hours_worked")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  employeeId   String   @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id])

  shiftId      String?  @map("shift_id")
  shift        Shift?   @relation(fields: [shiftId], references: [id])

  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("employee_work_hours")
  @@index([employeeId])
  @@index([date])
  @@index([departmentId])
}

// ============================================================
// WASTE & PAINT (CHIQINDI)
// ============================================================

model WasteRecord {
  id           String     @id @default(cuid())
  name         String
  quantity     Float
  date         DateTime   @db.Date
  notes        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")

  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("waste_records")
  @@index([departmentId])
  @@index([date])
}

model PaintRecord {
  id        String   @id @default(cuid())
  paintName String   @map("paint_name")
  quantity  Float
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  employeeId   String?    @map("employee_id")
  employee     Employee?  @relation(fields: [employeeId], references: [id])

  @@map("paint_records")
  @@index([departmentId])
  @@index([date])
}
